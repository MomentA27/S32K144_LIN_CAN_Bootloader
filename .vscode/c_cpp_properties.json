{
    "configurations": [
        {
            "name": "S32K144",
            "includePath": [
                "${workspaceFolder}/**"
            ],
            "defines": [
                "CPU_S32K144HFT0VLLT",
                "CPU_S32K144",
                "TURN_ON_CPU0",
                "START_FROM_FLASH",
                "__GNUC__",
                "USE_SDK_DRIVERS",
                "SDK_DEBUGCONSOLE=0",
                "_DEBUG"
            ],
            "compilerPath": "arm-none-eabi-gcc",
            "cStandard": "c99",
            "cppStandard": "c++17",
            "intelliSenseMode": "gcc-arm",
            "browse": {
                "path": [
                    "${workspaceFolder}/**"
                ],
                "limitSymbolsToIncludedHeaders": false
            }
        }
    ],
    "version": 4
}